{
  "expo": {
    "name": "TR Money",
    "slug": "tr-money",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo_FWH.png",
    "userInterfaceStyle": "light",
    "scheme": "trmoney",
    "splash": {
      "image": "./assets/Logo_FWH.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/Logo_FWH.png",
        "backgroundImage": "./assets/Logo_FWH.png",
        "monochromeImage": "./assets/Logo_FWH.png"
      }
    },
    "web": {
      "favicon": "./assets/Logo_FWH.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-sqlite"
    ]
  }
}
